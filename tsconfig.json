{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "erasableSyntaxOnly": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    ".astro/types.d.ts",
    "**/*",
    "src/**/*.tsx",
    "src/**/*.astro",
    "src/**/*.ts"
  ],
  "exclude": [
    "dist"
  ]
}